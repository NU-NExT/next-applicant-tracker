# Shared
ENVIRONMENT=development
AWS_REGION=us-east-1

# Local database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=next-ats-db
DB_PORT=5432

# Production database URL
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/next-ats-db

# Application ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
API_GATEWAY_PORT=8080

# Storage mode: local or s3
STORAGE_BACKEND=s3
LOCAL_STORAGE_PATH=/app/data

# S3 settings
S3_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=

# Cognito auth
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_APP_CLIENT_SECRET=
COGNITO_ADMIN_GROUP_NAME=ADMIN
# Optional shared team credentials used only for Cognito API calls.
# Keep AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY as `test` for LocalStack S3.
COGNITO_AWS_REGION=
COGNITO_AWS_ACCESS_KEY_ID=
COGNITO_AWS_SECRET_ACCESS_KEY=
COGNITO_AWS_SESSION_TOKEN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
# `cognito_hosted_ui_domain` (host only, no https://)
VITE_COGNITO_DOMAIN=
# cognito_app_client_id
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=http://localhost:3000/login
